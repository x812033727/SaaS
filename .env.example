# SaaS MVP 正式部署環境變數範本 — 複製為 .env 後修改（勿提交 .env）。
# 產生強密鑰：
#   SAAS_SECRET_KEY:               python -c "import secrets; print(secrets.token_hex(32))"
#   SAAS_LINE_CHANNEL_ENCRYPT_KEY: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# 非 dev 環境（prod）會強制要求上述兩個密鑰非預設值。
SAAS_ENV=prod
SAAS_SECRET_KEY=change-me-32-byte-hex-secret
SAAS_LINE_CHANNEL_ENCRYPT_KEY=change-me-fernet-key

# 對外絕對網址（組金流 ReturnURL / 公開頁 / 員工入口 / PII 表單連結用）
SAAS_PUBLIC_BASE_URL=https://your-domain.example

# 資料庫（compose 會以 db 服務組好 SAAS_DATABASE_URL；如獨立部署於此覆寫）
POSTGRES_USER=saas
POSTGRES_PASSWORD=change-me-db-password
POSTGRES_DB=saas

# 多 worker：gunicorn worker 數 + 對外埠
GUNICORN_WORKERS=4
WEB_PORT=8099
# Next.js 管理端僅綁主機 loopback，由 nginx 對外提供 TLS。
FRONTEND_PORT=3100

# 資料庫備份（db-backup 服務）：每日自動 pg_dump 到主機 ./backups
# BACKUP_TIME 為 UTC HHMM（預設 0300）；BACKUP_RETENTION_DAYS 為保留天數（超過即自動刪除）
BACKUP_RETENTION_DAYS=14
BACKUP_TIME=0300

# ── 選用整合（未填則對應功能走 stub / 停用）──────────────────────────────
# AI 客服（MiniMax M3，OpenAI-compatible API）；空 → StubAIAssistant
SAAS_MINIMAX_API_KEY=
SAAS_MINIMAX_BASE_URL=https://api.minimax.io/v1
SAAS_AI_MODEL=MiniMax-M3
# 簡訊 fallback(LINE 推播失敗時補發):SAAS_SMS_PROVIDER=mitake + 三竹帳密即真發,
# 否則 Stub 只記 log。另需 SAAS_SMS_FALLBACK_ENABLED=true 才會觸發。
SAAS_SMS_PROVIDER=stub
SAAS_MITAKE_USERNAME=
SAAS_MITAKE_PASSWORD=
# 翻譯（DeepL）；空 → StubTranslator
SAAS_DEEPL_API_KEY=
# OAuth 登入：正式環境必填；LINE Login Channel 與 Messaging API Channel 是不同產品，
# 不能混用憑證。LINE Developers Console callback URL 必須精確設定為：
# https://your-domain.example/auth/oauth/line/callback
SAAS_LINE_LOGIN_CHANNEL_ID=
SAAS_LINE_LOGIN_CHANNEL_SECRET=
SAAS_GOOGLE_OAUTH_CLIENT_ID=
SAAS_GOOGLE_OAUTH_CLIENT_SECRET=
# 多網域/反向代理時可顯式覆寫 OAuth callback base；留空使用 SAAS_PUBLIC_BASE_URL。
SAAS_OAUTH_REDIRECT_BASE=
# 金流（綠界 ECPay / 藍新 NewebPay）；預設為測試值，正式環境請覆寫
SAAS_PAYMENT_PROVIDER=stub

# ── 可觀測性（observability）──────────────────────────────────────────────
# 日誌格式：text（人類可讀）| json（log 聚合器，建議正式環境用）
SAAS_LOG_FORMAT=json
SAAS_LOG_LEVEL=INFO
# Prometheus /metrics：啟用開關 + 選用 bearer token（留空＝內網不設限）
SAAS_METRICS_ENABLED=true
SAAS_METRICS_TOKEN=

# LINE bot/info 憑證健康檢查（手動與背景共用每租戶預算）
SAAS_LINE_VERIFY_MAX_ATTEMPTS_PER_HOUR=3
SAAS_LINE_CREDENTIAL_REVERIFY_HOURS=24
SAAS_LINE_CREDENTIAL_REVERIFY_BATCH_SIZE=100
